{{#partial "body"}}
	<table width="100%" border="0" cellspacing="0" cellpadding="0" align="center">
		<tr>
			<td align="left" class="em_h1" style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:28px; line-height:40px; font-weight:700; color:#20406C;">
				{{pageTitle}}
			</td>
		</tr>
		<tr>
			<td align="left" style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:24px; line-height:36px; font-weight:700; color:#000000;">
				Community Highlights
			</td>
		</tr>
		<tr>
			<td height="24" style="height:24px; line-height:24px; font-size:1px;">&nbsp;</td>
		</tr>
		<tr>
			<td align="left" class="em_body_copy" style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:16px; line-height:24px; color:#292827;">
				An intro paragraph could go here. I wouldn&apos;t make it too long, so between 50-75 words would be the limit.
			</td>
		</tr>
		<tr>
			<td height="16" style="height:16px; line-height:16px; font-size:1px;">&nbsp;</td>
		</tr>
		<tr>
			<td style="border-top:1px solid #DBD7D3; line-height:1px; font-size:1px;">&nbsp;</td>
		</tr>
		<tr>
			<td height="16" style="height:16px; line-height:16px; font-size:1px;">&nbsp;</td>
		</tr>
		<tr>
			<td align="left" class="em_h2" style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:28px; line-height:40px; font-weight:700; color:#292827;">
				Upcoming Group Session
			</td>
		</tr>
		<tr>
			<td height="24" style="height:24px; line-height:24px; font-size:1px;">&nbsp;</td>
		</tr>
		{{#if upcomingGroupSessions}}
			{{#each upcomingGroupSessions}}
				<tr>
					<td align="center">
						{{#if imageUrl}}
							<img src="{{{imageUrl}}}" alt="Group Session" width="520" style="width:100%; max-width:520px; height:auto;" />
						{{else}}
							<table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color:#797979;">
								<tr>
									<td class="em_event_placeholder" height="292" align="center" valign="middle" style="height:292px;">
										<div style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:72px; line-height:72px; color:#FFFFFF; font-weight:400;">16:9</div>
										<div style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:16px; line-height:24px; color:#FFFFFF; font-weight:400;">Replace with image</div>
									</td>
								</tr>
							</table>
						{{/if}}
					</td>
				</tr>
				<tr>
					<td height="24" style="height:24px; line-height:24px; font-size:1px;">&nbsp;</td>
				</tr>
				<tr>
					<td align="left">
						<div class="em_session_title" style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:24px; line-height:36px; color:#000000; font-weight:700;">
							{{#if title}}{{title}}{{else}}Group Session Title{{/if}}
						</div>
						<div style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:14px; line-height:24px; color:#30578E; font-weight:700;">
							{{#if time}}
								{{#if month}}{{month}}{{#if day}} {{day}} at{{/if}} {{/if}}{{time}}
							{{else}}
								November 15 at 2:00PM (EST)
							{{/if}}
						</div>
						<div class="em_body_copy" style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:18px; line-height:24px; color:#000000; padding-top:8px; padding-bottom:24px;">
							{{#if description}}
								{{description}}
							{{else}}
								Description could go here. It could be the description from the group session or unique copy written specifically for the email.
							{{/if}}
						</div>
						<div align="center">
							<a href="{{#if reserveSeatUrl}}{{{reserveSeatUrl}}}{{else}}#{{/if}}" style="display:inline-block; font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:14px; line-height:20px; font-weight:600; color:#FFFFFF; text-decoration:none; background-color:#30578E; border-radius:800px; padding:10px 18px;">
								Reserve a seat
							</a>
						</div>
					</td>
				</tr>
				{{#unless @last}}
					<tr>
						<td height="24" style="height:24px; line-height:24px; font-size:1px;">&nbsp;</td>
					</tr>
				{{/unless}}
			{{/each}}
		{{else}}
			<tr>
				<td align="center">
					<table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color:#797979;">
						<tr>
							<td class="em_event_placeholder" height="292" align="center" valign="middle" style="height:292px;">
								<div style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:72px; line-height:72px; color:#FFFFFF; font-weight:400;">16:9</div>
								<div style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:16px; line-height:24px; color:#FFFFFF; font-weight:400;">Replace with image</div>
							</td>
						</tr>
					</table>
				</td>
			</tr>
			<tr>
				<td height="24" style="height:24px; line-height:24px; font-size:1px;">&nbsp;</td>
			</tr>
			<tr>
				<td align="left">
					<div class="em_session_title" style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:24px; line-height:36px; color:#000000; font-weight:700;">
						Group Session Title
					</div>
					<div style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:14px; line-height:24px; color:#30578E; font-weight:700;">
						November 15 at 2:00PM (EST)
					</div>
					<div class="em_body_copy" style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:18px; line-height:24px; color:#000000; padding-top:8px; padding-bottom:24px;">
						Description could go here. It could be the description from the group session or unique copy written specifically for the email.
					</div>
					<div align="center">
						<a href="#" style="display:inline-block; font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:14px; line-height:20px; font-weight:600; color:#FFFFFF; text-decoration:none; background-color:#30578E; border-radius:800px; padding:10px 18px;">
							Reserve a seat
						</a>
					</div>
				</td>
			</tr>
		{{/if}}
		<tr>
			<td height="24" style="height:24px; line-height:24px; font-size:1px;">&nbsp;</td>
		</tr>
		<tr>
			<td style="border-top:1px solid #DBD7D3; line-height:1px; font-size:1px;">&nbsp;</td>
		</tr>
		<tr>
			<td height="16" style="height:16px; line-height:16px; font-size:1px;">&nbsp;</td>
		</tr>
		<tr>
			<td align="left" class="em_body_copy" style="font-family:'SF Pro Text', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size:16px; line-height:24px; color:#292827;">
				Can&apos;t make this session? Visit the
				<a href="{{#if communityPageUrl}}{{{communityPageUrl}}}{{else}}#{{/if}}" style="color:#2C4F82; text-decoration:underline;">{{pageTitle}} Community Page</a>
				for additional resources including last month&apos;s group session recording on
				{<a href="{{#if recordingUrl}}{{{recordingUrl}}}{{else}}#{{/if}}" style="color:#30578E; text-decoration:underline;">{{#if recordingTitle}}{{recordingTitle}}{{else}}Group Session Title{{/if}}</a>}.
			</td>
		</tr>
	</table>
{{/partial}}

{{#partial "footer"}}
	You are receiving this email at {{#if recipientEmailAddress}}{{recipientEmailAddress}}{{else}}{emailaddress}{{/if}} because you subscribed to a page on
	<span style="color:#30578E;">{{#if platformName}}{{platformName}}{{else}}Cobalt{{/if}}</span>.
	If you need a little break, you can update your
	<a href="{{#if communicationPreferencesUrl}}{{{communicationPreferencesUrl}}}{{else}}#{{/if}}" style="color:#30578E; text-decoration:underline;">communication preferences</a>.
{{/partial}}

{{> layouts/en/v2}}
